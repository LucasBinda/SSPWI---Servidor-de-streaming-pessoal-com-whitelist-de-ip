# Dependências (mantido por precaução, caso algum pacote seja adicionado no futuro)
node_modules/

# Variáveis de ambiente / segredos
.env
.env.*

# Mídia — filmes e capas não devem ir pro Git (arquivos grandes,
# geralmente protegidos por direitos autorais, e pessoais)
media/movies/*
!media/movies/.gitkeep
media/covers/*
!media/covers/.gitkeep

# Catálogo real — é gerado/atualizado automaticamente pelo servidor e reflete
# sua coleção pessoal de filmes. Só o .example.json é versionado.
data/catalog.json

# Estado do worker de conversão pra mp4 — gerado em runtime,
# reflete o acervo local.
data/reencode-state.json

# Segredo HMAC das sessões — gerado no primeiro boot; vazar isso
# permitiria forjar cookies de sessão.
data/session-secret

# Whitelist de IP — evita vazar os IPs autorizados publicamente no repositório.
# Se preferir versionar um exemplo, use um "whitelist.example.json" à parte.
config/whitelist.json

# Caches gerados em runtime: legendas extraídas (cache/subs/) e temporários
# do worker de conversão pra mp4 (cache/reencode/).
cache/

# Logs
*.log
npm-debug.log*

# Sistema operacional
.DS_Store
Thumbs.db

# Editores
.vscode/
.idea/
*.swp
